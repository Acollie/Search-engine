shape: sequence_diagram

Spider -> Conductor: "gRPC connect (GetSeenList)"
Conductor -> Spider: "200 OK, stream ready"

loop: {
  label: "For each crawled page"
  Spider -> Conductor: "Page { url, title, body, links }"
  Conductor -> PostgreSQL: "Check if exists (url lookup)"
  alt: {
    label: "Page already exists"
    PostgreSQL -> Conductor: "Found (duplicate)"
    Conductor -> Conductor: "Skip"
  }
  alt: {
    label: "New page"
    PostgreSQL -> Conductor: "Not found"
    Conductor -> PostgreSQL: "INSERT SeenPages"
    Conductor -> PostgreSQL: "INSERT Queue (for links)"
  }
  Conductor -> Spider: "Backpressure (flow control)"
}

Spider -> Conductor: "Stream complete (EOF)"
Conductor -> PostgreSQL: "Flush pending writes"
