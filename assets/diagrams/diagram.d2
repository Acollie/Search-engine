direction: right

internet: "Internet 🌐"
user: "User"

k8s: {
  label: "Kubernetes Cluster (DigitalOcean)"

  lb: "⚙️ Traefik Ingress\n(LoadBalancer)"

  crawl: {
    label: "🕷️ Crawl Layer"
    spider: "Spider\n(gRPC :9001)"
    conductor: "Conductor\n(Hub)"
    spider <-> conductor: "gRPC stream\ncrawled pages"
  }

  rank: {
    label: "📊 Ranking Layer"
    cartographer: "Cartographer\n(CronJob)"
  }

  search: {
    label: "🔍 Search Layer"
    frontend: "Frontend\n(HTTP)"
    searcher: "Searcher\n(gRPC :9002)"
    frontend <-> searcher: "gRPC search"
  }

  observability: {
    label: "📊 Monitoring"
    prometheus: "Prometheus"
    grafana: "Grafana"
    prometheus -> grafana: "Metrics"
  }
}

database: "🗄️ PostgreSQL\n(Managed)"

user -> internet: "Browser"
internet -> k8s.lb: "search.collie.codes:443"
k8s.lb -> k8s.search.frontend: "HTTP"
k8s.search.searcher -> database: "Full-text search\n& PageRank"
k8s.crawl.spider -> database: "SQLite cache"
k8s.crawl.conductor -> database: "Deduplicate\n& store"
k8s.rank.cartographer -> database: "PageRank\ncomputation"
k8s.crawl.spider -> internet: "HTTP crawl"
k8s.observability.prometheus -> k8s.crawl.spider: "/metrics"
k8s.observability.prometheus -> k8s.crawl.conductor: "/metrics"
k8s.observability.prometheus -> k8s.search.searcher: "/metrics"
