shape: sequence_diagram

Spider -> Conductor: "Stream page 1"
Conductor -> PostgreSQL: "Write page 1"
Spider -> Conductor: "Stream page 2"
Conductor -> PostgreSQL: "Write page 2"
Spider -> Conductor: "Stream page 3"

backpressure: {
  label: "Queue depth > threshold"
  Conductor -> PostgreSQL: "Check queue depth"
  PostgreSQL -> Conductor: "depth = 5000 pages"
  Conductor -> Spider: "⏸️ Pause stream (backpressure)"
  Spider -> Spider: "Wait 1 second"
  Conductor -> PostgreSQL: "Check queue again"
  PostgreSQL -> Conductor: "depth = 3000 pages"
  Conductor -> Spider: "▶️ Resume stream"
  Spider -> Conductor: "Stream page 4"
}
