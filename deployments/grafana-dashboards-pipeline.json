{
  "title": "Search Engine - Data Pipeline",
  "description": "Production-optimized dashboard using pre-aggregated metrics. Configurable refresh: 5s (high-freq), 15s (default), 30s (low-overhead), 60s (minimal)",
  "tags": [
    "search-engine",
    "production"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "refreshIntervals": ["5s", "15s", "30s", "60s", "1m", "5m"],
  "uid": "pipeline-overview",
  "id": 1,
  "panels": [
    {
      "id": 1,
      "title": "Spider Pages Crawled/min",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "job:spider_crawl_rate:1m",
          "legendFormat": "Pages/min",
          "refId": "A",
          "datasourceUid": "prometheus"
        }
      ]
    },
    {
      "id": 2,
      "title": "Spider Error Rate %",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "job:spider_error_rate:1m * 100",
          "legendFormat": "Error %",
          "refId": "A",
          "datasourceUid": "prometheus"
        }
      ]
    },
    {
      "id": 3,
      "title": "Conductor Batches Processed/min",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "job:conductor_batches_rate:1m",
          "legendFormat": "Batches/min",
          "refId": "A",
          "datasourceUid": "prometheus"
        }
      ]
    },
    {
      "id": 4,
      "title": "Conductor Queue Depth",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "job:conductor_queue_depth:instant",
          "legendFormat": "Pending URLs",
          "refId": "A",
          "datasourceUid": "prometheus"
        }
      ]
    },
    {
      "id": 5,
      "title": "Pages Received from Spider",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "expr": "job:conductor_pages_received_rate:1m",
          "legendFormat": "Pages/min",
          "refId": "A",
          "datasourceUid": "prometheus"
        }
      ],
      "color": {
        "mode": "thresholds"
      },
      "thresholds": {
        "mode": "absolute",
        "steps": [
          {
            "color": "red",
            "value": null
          },
          {
            "color": "yellow",
            "value": 1
          },
          {
            "color": "green",
            "value": 2
          }
        ]
      }
    },
    {
      "id": 6,
      "title": "Searcher Queries/min",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "expr": "job:searcher_queries_rate:1m",
          "legendFormat": "Queries/min",
          "refId": "A",
          "datasourceUid": "prometheus"
        }
      ],
      "color": {
        "mode": "thresholds"
      },
      "thresholds": {
        "mode": "absolute",
        "steps": [
          {
            "color": "red",
            "value": null
          },
          {
            "color": "yellow",
            "value": 1
          },
          {
            "color": "green",
            "value": 2
          }
        ]
      }
    }
  ]
}