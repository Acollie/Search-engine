      "title": "Microservices",
      "type": "stat",
      "description": "Distinct services reporting metrics right now",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 7 },
      "targets": [
        { "expr": "count(count by (job) (up))", "refId": "A", "datasourceUid": "prometheus" }
      ],
