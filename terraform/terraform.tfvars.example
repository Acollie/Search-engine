# Copy to terraform.tfvars and fill in real values.
# terraform.tfvars is gitignored — never commit it.

hcloud_token   = "your_hetzner_cloud_api_token_here"
do_token       = "dop_v1_your_digitalocean_token_here"  # kept for collie.codes DNS only
ssh_public_key = "ssh-ed25519 AAAA... your-key-comment"

# Optional overrides (defaults are production-ready):
# location            = "fsn1"          # Falkenstein, Germany
# k3s_version         = "v1.32.5+k3s1"
# control_plane_type  = "cx32"
# worker_type         = "cx32"
# worker_count        = 2
# allowed_ssh_ips     = ["YOUR_IP/32"]  # tighten before going live
# acme_email          = "alex@collie.codes"
